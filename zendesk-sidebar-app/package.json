{
  "name": "zendesk-ado-sidebar-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Private Zendesk sidebar app for the DevAzure Zendesk sync project",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "start": "zcli apps:server src",
    "start:prod": "zcli apps:server dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@zendeskgarden/css-bedrock": "^9.1.1",
    "@zendeskgarden/react-buttons": "^8.76.3",
    "@zendeskgarden/react-forms": "^8.76.3",
    "@zendeskgarden/react-loaders": "^8.76.3",
    "@zendeskgarden/react-theming": "^8.76.3",
    "@zendeskgarden/react-typography": "^8.76.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^5.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "fast-glob": "^3.3.2",
    "jsdom": "^24.1.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}

# DevAzure-Zendesk Sync
# Assumption: sync Zendesk ticket events into DevAzure work items.
# Copy this file to .env and fill with real credentials.

# Server
PORT=8787
WEBHOOK_PATH=/webhooks/zendesk
SYNC_DRY_RUN=true

# Optional extra inbound auth in addition to Zendesk request signatures
# INBOUND_BEARER_TOKEN=
# Optional operator API token for /internal/jobs/dead and /internal/jobs/:id/retry
# INTERNAL_ADMIN_TOKEN=replace-with-a-long-random-string
# Optional webhook destination for critical sync alerts such as 401/403 auth failures
# SYNC_ADMIN_ALERT_WEBHOOK_URL=https://example.com/sync-alerts
# Keep ADO comment back-sync bounded so old discussions do not flood Zendesk
# COMMENT_SYNC_MAX_AGE_HOURS=24
# Maximum Zendesk attachment size copied into ADO, in bytes
# SYNC_MAX_ATTACHMENT_BYTES=10485760

# Zendesk webhook verification
ZENDESK_WEBHOOK_SECRET=replace-with-your-zendesk-signing-secret
ZENDESK_BASE_URL=https://your-subdomain.zendesk.com
# Set to true only for local smoke testing when signatures are not available.
ZENDESK_SKIP_SIGNATURE_VERIFICATION=false

# Zendesk API (for creating/updating ticket fields and adding internal notes)
# Username must be the full email address, auth format is {email}/token:{token}
ZENDESK_API_USERNAME=you@example.com
ZENDESK_API_TOKEN=replace-with-your-zendesk-api-token

# Zendesk sidebar app — shared secret used to verify ZAF JWTs on
# /app/ado/tickets/:id/* requests. Set the same value in the Zendesk
# app's secure settings. Leave unset to disable /app/* routes.
# ZENDESK_APP_SHARED_SECRET=replace-with-a-long-random-string
# Comma-separated Zendesk form IDs allowed to use /app/* sidebar routes.
# Defaults to the pilot form. Use "*" only for an explicitly approved full rollout.
# ZENDESK_APP_ALLOWED_FORM_IDS=50882600373907
# Optional Zendesk custom ticket status id for the BRD "Dev Completed" status.
# When set, ADO Support Ready can move the native Zendesk custom status.
# ZENDESK_DEV_COMPLETED_STATUS_ID=

# Zendesk webhook registration (scripts/register-zendesk-webhook.mjs)
# ZENDESK_WEBHOOK_URL=https://zendesk-sync.example.com/webhooks/zendesk
# ZENDESK_WEBHOOK_NAME=ADO Integration — ticket events
# Comma-separated event-type subscriptions (see developer.zendesk.com/api-reference/webhooks/event-types)
# ZENDESK_WEBHOOK_EVENTS=zen:event-type:ticket.created,zen:event-type:ticket.comment_added
# ZENDESK_WEBHOOK_PRINT_SECRET=false

# Oracle (sync ledger, worker tables, audit)
# Connect string format: hostname/service (thin mode, no Oracle Instant Client needed)
ORACLE_DB_HOST=srv-db-100
ORACLE_DB_PORT=1521
ORACLE_DB_SERVICE=SUPPOPS
ORACLE_DB_USERNAME=automation
ORACLE_DB_PASSWORD=replace-with-your-oracle-password

# DevAzure / Azure DevOps
DEVAZURE_ORG_URL=https://dev.azure.com/your-org
DEVAZURE_PROJECT=VisionSuite
DEVAZURE_PAT=replace-with-your-pat
DEVAZURE_WORK_ITEM_TYPE=Bug
# Optional routing defaults
# DEVAZURE_AREA_PATH=YourProject\\Support
# DEVAZURE_ITERATION_PATH=YourProject
# DEVAZURE_ASSIGNED_TO=dev-team@yourcompany.com
# Explicit ADO target-date field wins over sprint finish date for ETA.
# DEVAZURE_TARGET_DATE_FIELD=Microsoft.VSTS.Scheduling.TargetDate
# Optional JSON map of Zendesk assignee user id -> ADO identity.
# ZENDESK_ASSIGNEE_ADO_MAP={"123456789":"dev@example.com"}
# ADO service-hook webhook (Basic auth — set the same values on the subscription)
# DEVAZURE_WEBHOOK_PATH=/webhooks/ado
# DEVAZURE_WEBHOOK_USERNAME=replace-with-hook-user
# DEVAZURE_WEBHOOK_PASSWORD=replace-with-hook-password

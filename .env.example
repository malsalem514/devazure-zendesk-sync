# DevAzure-Zendesk Sync
# Assumption: sync Zendesk ticket events into DevAzure work items.
# Copy this file to .env and fill with real credentials.

# Server
PORT=8787
WEBHOOK_PATH=/webhooks/zendesk
SYNC_DRY_RUN=true

# Optional extra inbound auth in addition to Zendesk request signatures
# INBOUND_BEARER_TOKEN=

# Zendesk webhook verification
ZENDESK_WEBHOOK_SECRET=replace-with-your-zendesk-signing-secret
ZENDESK_BASE_URL=https://your-subdomain.zendesk.com
# Set to true only for local smoke testing when signatures are not available.
ZENDESK_SKIP_SIGNATURE_VERIFICATION=false

# Zendesk API (for creating/updating ticket fields and adding internal notes)
# Username must be the full email address, auth format is {email}/token:{token}
ZENDESK_API_USERNAME=you@example.com
ZENDESK_API_TOKEN=replace-with-your-zendesk-api-token

# Oracle (sync ledger, worker tables, audit)
# Connect string format: hostname/service (thin mode, no Oracle Instant Client needed)
ORACLE_DB_HOST=srv-db-100
ORACLE_DB_PORT=1521
ORACLE_DB_SERVICE=SUPPOPS
ORACLE_DB_USERNAME=automation
ORACLE_DB_PASSWORD=replace-with-your-oracle-password

# DevAzure / Azure DevOps
DEVAZURE_ORG_URL=https://dev.azure.com/your-org
DEVAZURE_PROJECT=VisionSuite
DEVAZURE_PAT=replace-with-your-pat
DEVAZURE_WORK_ITEM_TYPE=Bug
# Optional routing defaults
# DEVAZURE_AREA_PATH=YourProject\\Support
# DEVAZURE_ITERATION_PATH=YourProject
# DEVAZURE_ASSIGNED_TO=dev-team@yourcompany.com

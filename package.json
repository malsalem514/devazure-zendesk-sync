{
  "name": "devazure-zendesk-sync",
  "version": "0.1.0",
  "private": true,
  "description": "Starter service for syncing Zendesk ticket events into DevAzure work items",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "npm run build && node --test test/*.test.mjs",
    "package:standalone": "npm run build && node ./scripts/package-standalone.mjs",
    "app:install": "npm --prefix zendesk-sidebar-app install",
    "app:dev": "npm --prefix zendesk-sidebar-app run dev",
    "app:build": "npm --prefix zendesk-sidebar-app run build"
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "README.md",
    "CLIENT-HANDOFF.md",
    ".env.example",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=24.14.0 <25.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "azure-devops-node-api": "^15.1.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "node-cron": "^3.0.3",
    "node-zendesk": "^6.0.1",
    "oracledb": "^6.10.0"
  }
}
